<% layout("/layouts/boilerplate") %>

<div class="container mt-5">
    <div class="row">
        <div class="alert alert-danger col-6 offset-3 text-center shadow">

            <h4 class="alert-heading">Something went wrong ⚠️</h4>
            
            <hr>

            <!-- Error message -->
            <p>
                <%= err.message %>
            </p>

            <!-- Status code (optional) -->
            <% if (err.statusCode) { %>
                <p><b>Status Code:</b> <%= err.statusCode %></p>
            <% } %>

            <!-- Back button -->
            <a href="/listings" class="btn btn-dark mt-3">
                Go Back
            </a>

        </div>
    </div>
</div>
